{
  "name": "@kartverket/backstage-plugin-risk-scorecard-backend",
  "version": "0.0.0-development",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "MIT",
  "repository": {
    "url": "git+https://github.com/kartverket/backstage-plugin-risk-scorecard-frontend.git"
  },
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
  },
  "engines": {
    "node": "24"
  },
  "configSchema": "config.d.ts",
  "backstage": {
    "role": "backend-plugin",
    "pluginId": "risk-scorecard",
    "pluginPackages": [
      "@kartverket/backstage-plugin-risk-scorecard",
      "@kartverket/backstage-plugin-risk-scorecard-backend"
    ]
  },
  "scripts": {
    "start": "backstage-cli package start",
    "build:types": "yarn run -T tsc",
    "build": "yarn build:types && backstage-cli package build",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack"
  },
  "dependencies": {
    "@backstage/backend-plugin-api": "backstage:^",
    "@backstage/catalog-client": "backstage:^",
    "@backstage/catalog-model": "backstage:^",
    "@backstage/config": "backstage:^",
    "@backstage/integration": "backstage:^",
    "@kartverket/ros-common": "workspace:*",
    "age-encryption": "^0.3.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "express": "^4.22.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@backstage/backend-test-utils": "backstage:^",
    "@backstage/cli": "backstage:^",
    "@types/express": "^4.17.21",
    "@types/supertest": "^7.2.0",
    "jest": "catalog:",
    "knex": "^3.0.0",
    "supertest": "^7.2.2"
  },
  "files": [
    "dist",
    "config.d.ts"
  ]
}
