{
  "name": "root",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "24"
  },
  "workspaces": {
    "packages": [
      "ros",
      "build-tools",
      "ros-backend"
    ]
  },
  "scripts": {
    "prettier:check": "prettier --check \"ros/src/**/*.{js,jsx,ts,tsx,mjs,cjs}\"",
    "prettier:write": "prettier --write \"ros/src/**/*.{js,jsx,ts,tsx,mjs,cjs}\"",
    "lint": "eslint \"ros/src/**/*.{js,jsx,ts,tsx,mjs,cjs}\"",
    "test:all": "yarn workspace build-tools test",
    "typecheck": "yarn workspace @kartverket/backstage-plugin-risk-scorecard tsc && yarn workspace build-tools tsc"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "yarn@4.14.1"
}
