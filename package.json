{
  "name": "root",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "24"
  },
  "workspaces": {
    "packages": [
      "plugins/*",
      "build-tools"
    ]
  },
  "scripts": {
    "prettier:check": "prettier --check \"ros/src/**/*.{js,jsx,ts,tsx,mjs,cjs}\"",
    "prettier:write": "prettier --write \"ros/src/**/*.{js,jsx,ts,tsx,mjs,cjs}\"",
    "lint": "eslint \"ros/src/**/*.{js,jsx,ts,tsx,mjs,cjs}\"",
    "test:all": "yarn workspace build-tools test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "yarn@4.9.2"
}
